# MT5 Trading Bridge — Environment Variables

# ─── Ports ───────────────────────────────────────────────────────────────────
MT5_HTTP_PORT=1080
MT5_TCP_PORT=1081
RELAY_PORT=1082

# ─── Copy-Trade Forwarder ───────────────────────────────────────────────────
# Forward nhận lệnh sang server khác sau khi nhận từ MT5
# Body format: action=BUY|symbol=EURUSD|lot=0.10|price=0.00000|sl=1.08000|tp=1.09000|magic=12345|comment=
#
# Ví dụ: forward sang 1Broker copy-trade server
# FORWARD_TO_URL=http://103.72.56.53:8080/signal
FORWARD_TO_URL=http://103.72.56.53:8080
