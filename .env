# MT5 Trading Bridge — Environment Variables

# ─── Ports ───────────────────────────────────────────────────────────────────
MT5_HTTP_PORT=1080
MT5_TCP_PORT=1081
RELAY_PORT=1082
API_PORT=1083

POSTGRES_PORT=1090
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=mt5_bridge

REDIS_PORT=1091
REDIS_PASSWORD=admin123

# ─── Copy-Trade Forwarder ───────────────────────────────────────────────────
# Forward nhận lệnh sang server TCP khác sau khi nhận từ MT5
# Body format: action=BUY|symbol=EURUSD|lot=0.10|price=0.00000|sl=1.08000|tp=1.09000|magic=12345|comment=
#
# Ví dụ: forward sang 1Broker copy-trade server
# FORWARD_TO_HOST=103.72.56.53
# FORWARD_TO_PORT=8080
FORWARD_TO_HOST=103.72.56.53
FORWARD_TO_PORT=8080

# ─── Master-Follower System ──────────────────────────────────────────────────
# JWT Secret for API authentication (change in production!)
JWT_SECRET=your-secret-key-change-in-production

# Database URL for master-follower components
DATABASE_URL=postgres://admin:admin123@localhost:1090/mt5_bridge?sslmode=disable

# Redis configuration
REDIS_HOST=localhost
REDIS_DB=0
REDIS_POOL_SIZE=20
